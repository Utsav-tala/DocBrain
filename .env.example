# =============================================================================
# DocBrain — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# ⚠️  NEVER commit your real .env file. It is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# OpenAI (Required for LLM + Embeddings)
# -----------------------------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
# Used for: GPT-4o / GPT-4o-mini responses + text-embedding-3-small embeddings
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Google Gemini (Optional — fallback LLM)
# -----------------------------------------------------------------------------
# Get your key at: https://aistudio.google.com/app/apikey
# Only required if you configure MODEL_NAME to use a Gemini model
GOOGLE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# -----------------------------------------------------------------------------
# Model Selection
# -----------------------------------------------------------------------------
# Which LLM to use. Supported values:
#   gpt-4o          → OpenAI GPT-4o (best quality, higher cost)
#   gpt-4o-mini     → OpenAI GPT-4o-mini (faster, cheaper)
#   gemini-1.5-pro  → Google Gemini 1.5 Pro (requires GOOGLE_API_KEY)
MODEL_NAME=gpt-4o-mini


# -----------------------------------------------------------------------------
# GitHub Token (Optional — only needed for ingesting GitHub Issues)
# -----------------------------------------------------------------------------
# Get a token at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only)
# Only needed if you enable the GitHub issues data source in ingest.py
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX