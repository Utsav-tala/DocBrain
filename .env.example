# =============================================================================
# DocBrain — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# ⚠️  NEVER commit your real .env file. It is already in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# OpenAI (Required — LLM + Embeddings)
# -----------------------------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
# Used for: GPT-4o / GPT-4o-mini responses + text-embedding-3-small embeddings
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Model Selection (Optional)
# -----------------------------------------------------------------------------
# Default chat model — also selectable in the app sidebar. Supported values:
#   gpt-4o-mini   → faster, cheaper (default)
#   gpt-4o        → best quality, higher cost
#   gpt-4-turbo
MODEL_NAME=gpt-4o-mini


# -----------------------------------------------------------------------------
# GitHub Token (Optional — only for rebuilding the index with GitHub Issues)
# -----------------------------------------------------------------------------
# Get a token at: https://github.com/settings/tokens
# Required scope: public_repo (read-only). Only needed for `python -m src.ingest`.
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# -----------------------------------------------------------------------------
# Vector DB source (Optional — cloud deploy only)
# -----------------------------------------------------------------------------
# On a fresh deploy the prebuilt Chroma index isn't in git, so the app downloads
# it from a GitHub Release on first run (see src/bootstrap_db.py). Override this
# only if you cut a new release tag; locally it's ignored (the DB already exists).
# DOCBRAIN_DB_URL=https://github.com/Utsav-tala/DocBrain/releases/download/db-v5/chroma_langchain.zip
